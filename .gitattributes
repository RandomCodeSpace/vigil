# VIGIL scripts: pin to LF line endings + UTF-8 BOM so Windows PowerShell 5.1
# reads them consistently regardless of core.autocrlf settings.
*.ps1        text eol=lf working-tree-encoding=UTF-8-BOM
*.ps1xml     text eol=lf working-tree-encoding=UTF-8-BOM
*.md         text eol=lf
*.json       text eol=lf
*.gitignore  text eol=lf
*.gitattributes text eol=lf
